{
  "themeName": "Officine Générale - Brutalist Chic Design System",
  "visualDirection": {
    "style": "Brutalist Minimalist / Editorial High-Fashion",
    "atmosphere": "Premium, high-contrast, raw typographic power, structured editorial grid, anti-decorative",
    "imageTreatment": "Strict black and white, high contrast, desaturated, editorial framing, portrait and full-body compositions"
  },
  "typography": {
    "displayFont": {
      "family": "Anton",
      "fallback": "Impact, 'Arial Black', sans-serif",
      "googleFontsUrl": "https://fonts.google.com/specimen/Anton",
      "weights": [400],
      "tracking": "-0.02em",
      "leading": "0.88"
    },
    "bodyFont": {
      "family": "Barlow Condensed",
      "fallback": "'Arial Narrow', Helvetica, sans-serif",
      "googleFontsUrl": "https://fonts.google.com/specimen/Barlow+Condensed",
      "weights": [400, 500, 700],
      "tracking": "0.08em",
      "leading": "1.4"
    },
    "scale": {
      "heroTitle": {
        "fontSize": "clamp(80px, 12vw, 160px)",
        "lineHeight": "0.88",
        "letterSpacing": "-0.02em",
        "textTransform": "uppercase",
        "fontWeight": 400,
        "fontFamily": "Anton"
      },
      "sectionTitle": {
        "fontSize": "clamp(36px, 5vw, 72px)",
        "lineHeight": "0.92",
        "letterSpacing": "-0.01em",
        "textTransform": "uppercase",
        "fontWeight": 400,
        "fontFamily": "Anton"
      },
      "editorialHeadline": {
        "fontSize": "clamp(40px, 6vw, 80px)",
        "lineHeight": "0.90",
        "letterSpacing": "-0.015em",
        "textTransform": "uppercase",
        "fontWeight": 400,
        "fontFamily": "Anton"
      },
      "productTitle": {
        "fontSize": "clamp(18px, 2vw, 26px)",
        "lineHeight": "1.1",
        "letterSpacing": "0.06em",
        "textTransform": "uppercase",
        "fontWeight": 700,
        "fontFamily": "Barlow Condensed"
      },
      "productSubtitle": {
        "fontSize": "11px",
        "lineHeight": "1.3",
        "letterSpacing": "0.10em",
        "textTransform": "uppercase",
        "fontWeight": 500,
        "fontFamily": "Barlow Condensed"
      },
      "body": {
        "fontSize": "12px",
        "lineHeight": "1.5",
        "letterSpacing": "0.04em",
        "textTransform": "uppercase",
        "fontWeight": 400,
        "fontFamily": "Barlow Condensed"
      },
      "navigation": {
        "fontSize": "11px",
        "lineHeight": "1.0",
        "letterSpacing": "0.12em",
        "textTransform": "uppercase",
        "fontWeight": 500,
        "fontFamily": "Barlow Condensed"
      },
      "tickerText": {
        "fontSize": "clamp(14px, 1.8vw, 20px)",
        "lineHeight": "1.0",
        "letterSpacing": "0.06em",
        "textTransform": "uppercase",
        "fontWeight": 700,
        "fontFamily": "Barlow Condensed"
      },
      "footerBrand": {
        "fontSize": "clamp(48px, 8vw, 100px)",
        "lineHeight": "0.88",
        "letterSpacing": "-0.02em",
        "textTransform": "uppercase",
        "fontWeight": 400,
        "fontFamily": "Anton"
      }
    }
  },
  "colorPalette": {
    "backgrounds": {
      "primary": "#FFFFFF",
      "secondary": "#F0EFED",
      "textured": "#C8C5BE",
      "darkSection": "#111111",
      "footerBlack": "#0A0A0A"
    },
    "text": {
      "primary": "#0A0A0A",
      "secondary": "#2A2A2A",
      "muted": "#5A5A5A",
      "inverted": "#FFFFFF",
      "invertedMuted": "#AAAAAA"
    },
    "borders": {
      "thin": "#0A0A0A",
      "thinLight": "#D0CFC9",
      "thick": "#0A0A0A",
      "thickWidth": "2px",
      "thinWidth": "1px",
      "style": "solid"
    },
    "accents": {
      "tickerBg": "#0A0A0A",
      "tickerText": "#FFFFFF",
      "tickerDivider": "#FFFFFF",
      "badgeBg": "#0A0A0A",
      "badgeText": "#FFFFFF",
      "ctaHoverBg": "#FFFFFF",
      "ctaHoverText": "#0A0A0A"
    },
    "imageFilter": {
      "type": "grayscale",
      "contrast": "110%",
      "brightness": "95%"
    }
  },
  "layoutAndSpacing": {
    "grid": {
      "desktopColumns": 12,
      "tabletColumns": 8,
      "mobileColumns": 4,
      "containerMaxWidth": "1280px",
      "containerPadding": "0px",
      "gutterWidth": "0px",
      "note": "Zero-gutter brutalist grid — borders replace gutters"
    },
    "borders": {
      "sectionBorderWidth": "2px",
      "productCardBorderWidth": "1px",
      "heroBorderWidth": "2px",
      "style": "solid",
      "color": "#0A0A0A"
    },
    "spacingScale": {
      "xs": "4px",
      "sm": "8px",
      "md": "16px",
      "lg": "32px",
      "xl": "64px",
      "xxl": "96px"
    },
    "navHeight": "48px",
    "sectionPadding": {
      "vertical": "48px",
      "horizontal": "0px"
    }
  },
  "components": {
    "navigation": {
      "height": "48px",
      "background": "#FFFFFF",
      "borderBottom": "2px solid #0A0A0A",
      "layout": "space-between horizontal",
      "logoPosition": "center",
      "linksAlignment": "distributed",
      "textStyle": {
        "fontSize": "11px",
        "letterSpacing": "0.12em",
        "textTransform": "uppercase",
        "fontWeight": 500
      }
    },
    "buttons": {
      "primary": {
        "background": "#0A0A0A",
        "text": "#FFFFFF",
        "borderRadius": "0px",
        "padding": "10px 20px",
        "border": "2px solid #0A0A0A",
        "fontSize": "10px",
        "fontWeight": 700,
        "letterSpacing": "0.12em",
        "textTransform": "uppercase",
        "hasArrow": true,
        "arrowStyle": "▶",
        "hoverBg": "#FFFFFF",
        "hoverText": "#0A0A0A",
        "hoverBorder": "2px solid #0A0A0A",
        "transition": "background 0.15s ease, color 0.15s ease"
      },
      "secondary": {
        "background": "transparent",
        "text": "#0A0A0A",
        "border": "2px solid #0A0A0A",
        "borderRadius": "0px",
        "padding": "8px 16px",
        "fontSize": "10px",
        "letterSpacing": "0.12em",
        "textTransform": "uppercase"
      },
      "ghost": {
        "background": "transparent",
        "text": "#FFFFFF",
        "border": "2px solid #FFFFFF",
        "borderRadius": "0px",
        "padding": "8px 16px",
        "fontSize": "10px",
        "letterSpacing": "0.12em",
        "textTransform": "uppercase"
      }
    },
    "tickerTape": {
      "variants": {
        "horizontal": {
          "background": "#0A0A0A",
          "text": "#FFFFFF",
          "fontSize": "14px",
          "fontWeight": 700,
          "letterSpacing": "0.08em",
          "textTransform": "uppercase",
          "paddingVertical": "14px",
          "divider": "✳",
          "dividerSpacing": "24px",
          "animationDirection": "left",
          "animationDuration": "20s"
        },
        "slanted": {
          "background": "#0A0A0A",
          "text": "#FFFFFF",
          "fontSize": "14px",
          "fontWeight": 700,
          "letterSpacing": "0.08em",
          "textTransform": "uppercase",
          "slantAngle": "-3deg",
          "transform": "rotate(-3deg)",
          "overflowHidden": true,
          "zIndex": 10,
          "paddingVertical": "12px",
          "marginVertical": "-8px",
          "divider": "✳"
        }
      }
    },
    "heroSection": {
      "layout": "full-bleed",
      "titleOverflow": "overflow-hidden bleed-edges",
      "subGrid": {
        "columns": "1fr 2fr",
        "leftPanel": {
          "background": "#C8C5BE",
          "subPanels": 2,
          "topPanel": "brand-icon centered",
          "bottomPanel": "brand-description + CTA",
          "border": "2px solid #0A0A0A"
        },
        "rightPanel": {
          "type": "editorial-photo",
          "aspectRatio": "4/3",
          "filter": "grayscale(100%) contrast(110%)"
        }
      }
    },
    "productCards": {
      "layout": "asymmetric-editorial-grid",
      "structure": {
        "featured": {
          "span": "full-width",
          "aspectRatio": "16/9",
          "hasOverlayLabel": true,
          "labelPosition": "bottom-left",
          "labelStyle": "SHOP THE COLLECTION — uppercase, bold"
        },
        "grid": {
          "columns": 3,
          "aspectRatio": "2/3",
          "gap": "0px",
          "border": "1px solid #D0CFC9"
        }
      },
      "textAlignment": "left",
      "showPrice": false,
      "showCTA": true,
      "ctaStyle": {
        "text": "STYLE ▶",
        "fontSize": "10px",
        "fontWeight": 700,
        "letterSpacing": "0.10em",
        "textTransform": "uppercase",
        "color": "#0A0A0A"
      },
      "imageFilter": "grayscale(100%) contrast(108%)",
      "hoverEffect": "subtle scale 1.02, 0.3s ease"
    },
    "brandIcon": {
      "type": "Asterisk",
      "character": "✳",
      "points": 8,
      "style": "solid filled geometric",
      "usage": [
        "ticker tape divider",
        "section separator",
        "hero branding block",
        "inline editorial element"
      ],
      "sizes": {
        "large": "80px",
        "medium": "24px",
        "small": "16px"
      },
      "colorOnDark": "#FFFFFF",
      "colorOnLight": "#0A0A0A"
    },
    "sectionHeader": {
      "layout": "flex space-between align-baseline",
      "titleAlign": "left",
      "ctaAlign": "right",
      "borderTop": "2px solid #0A0A0A",
      "paddingTop": "16px",
      "marginBottom": "0px"
    },
    "newsletter": {
      "background": "#0A0A0A",
      "text": "#FFFFFF",
      "inputStyle": {
        "background": "transparent",
        "border": "none",
        "borderBottom": "1px solid #FFFFFF",
        "color": "#FFFFFF",
        "placeholderColor": "#666666",
        "fontSize": "11px",
        "letterSpacing": "0.08em"
      },
      "submitArrow": "→"
    },
    "footer": {
      "background": "#0A0A0A",
      "text": "#FFFFFF",
      "brandWordmark": {
        "fontSize": "clamp(48px, 8vw, 100px)",
        "fontFamily": "Anton",
        "textTransform": "uppercase",
        "letterSpacing": "-0.02em",
        "color": "#FFFFFF"
      },
      "linksStyle": {
        "fontSize": "10px",
        "letterSpacing": "0.10em",
        "textTransform": "uppercase",
        "color": "#888888"
      },
      "borderTop": "1px solid #333333"
    }
  },
  "uiElements": {
    "noiseTexture": {
      "applyTo": ["heroLeftPanel", "texturedBlocks"],
      "type": "CSS filter or SVG feTurbulence",
      "intensity": "subtle grain",
      "opacity": "0.08",
      "blendMode": "overlay",
      "cssFilter": "url(#grain)",
      "suggestedImplementation": "svg feTurbulence baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'"
    },
    "imageFilters": {
      "global": "grayscale(100%)",
      "contrast": "contrast(108%)",
      "brightness": "brightness(95%)",
      "hoverTransition": "contrast 0.3s ease"
    },
    "microinteractions": {
      "buttonHover": "instant background invert, 0.15s",
      "navLinkHover": "underline appear",
      "tickerAnimation": "infinite marquee scroll left",
      "productImageHover": "scale(1.02), 0.3s ease",
      "ctaArrow": "translate(4px) on hover"
    },
    "scrollBehavior": {
      "tickerOnScroll": "fixed position during section overlap",
      "slantedTicker": "breaks grid with negative margin overlap"
    }
  },
  "designTokens": {
    "--font-display": "'Anton', Impact, 'Arial Black', sans-serif",
    "--font-body": "'Barlow Condensed', 'Arial Narrow', sans-serif",
    "--color-black": "#0A0A0A",
    "--color-white": "#FFFFFF",
    "--color-gray-light": "#F0EFED",
    "--color-gray-mid": "#C8C5BE",
    "--color-gray-dark": "#5A5A5A",
    "--border-thin": "1px solid #0A0A0A",
    "--border-thick": "2px solid #0A0A0A",
    "--border-light": "1px solid #D0CFC9",
    "--spacing-xs": "4px",
    "--spacing-sm": "8px",
    "--spacing-md": "16px",
    "--spacing-lg": "32px",
    "--spacing-xl": "64px",
    "--spacing-xxl": "96px",
    "--tracking-tight": "-0.02em",
    "--tracking-normal": "0.04em",
    "--tracking-wide": "0.10em",
    "--tracking-wider": "0.12em",
    "--leading-brutal": "0.88",
    "--leading-tight": "1.1",
    "--leading-body": "1.5",
    "--container-max": "1280px",
    "--radius": "0px",
    "--transition-fast": "0.15s ease",
    "--transition-mid": "0.3s ease"
  }
}